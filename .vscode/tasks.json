{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "front: start",
      "type": "shell",
      "command": "npm",
      "args": ["start", "--prefix", "angular"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "backend: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "--prefix", "backend"],
      "isBackground": true
    }
  ]
}
